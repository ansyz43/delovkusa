# Database — укажите URL вашей Supabase PostgreSQL БД или любой другой PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/confectionery

# Секретный ключ для JWT — сгенерируйте случайную строку: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# Google OAuth — получите в https://console.cloud.google.com/ → Credentials → OAuth Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram Login — токен бота для авторизации (получите у @BotFather)
TELEGRAM_BOT_TOKEN_LOGIN=

# CORS — разрешённые домены (через запятую)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cookies — поставьте true в production (HTTPS обязателен)
COOKIE_SECURE=false
